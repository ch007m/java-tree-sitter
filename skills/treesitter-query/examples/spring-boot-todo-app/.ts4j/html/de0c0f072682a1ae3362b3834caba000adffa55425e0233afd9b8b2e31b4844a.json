  "sourceCode" : "<!DOCTYPE html>\n<html xmlns:th=\"http://www.thymeleaf.org\" lang=\"en\">\n\n<head>\n  <title>ToDo | Error Page</title>\n  <!-- Add Bootstrap CSS and JavaScript -->\n  <link href=\"https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css\" rel=\"stylesheet\">\n  <script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js\"></script>\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.16.0/umd/popper.min.js\"></script>\n  <script src=\"https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js\"\n    integrity=\"sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM\"\n    crossorigin=\"anonymous\"></script>\n  <script src=\"https://code.jquery.com/jquery-3.6.0.min.js\"></script>\n</head>\n\n<style>\n  /* custom-error.css */\n\n  /* Center the error content vertically and horizontally */\n  body {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    height: 100vh;\n  }\n\n  /* Add a background color and increase text size */\n  .text-center {\n    padding: 20px;\n    border-radius: 10px;\n  }\n\n  .display-4 {\n    font-size: 3rem;\n  }\n\n  /* Style the \"Go to Home\" button */\n  .btn-primary {\n    background-color: #007bff;\n    border-color: #007bff;\n    font-size: 1.5rem;\n    padding: 8px 24px;\n  }\n\n  .btn-primary:hover {\n    background-color: #0056b3;\n    border-color: #0056b3;\n  }\n</style>\n\n<body>\n  <div class=\"container\">\n    <div class=\"text-center\">\n      <h1 class=\"display-4\">Oops! It seems there's a bug \uD83D\uDC1E</h1>\n      <p class=\"display-5 lead m-3\">We're sorry for this. Let's go back to home.</p>\n      <p><a th:href=\"@{/home}\" class=\"btn btn-outline-primary\">Go to Home</a></p>\n    </div>\n  </div>\n</body>\n\n</html>",
